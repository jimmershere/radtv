# Normalize line endings.
* text=auto eol=lf

# Shell + Python: enforce LF
*.sh    text eol=lf
*.py    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.xml   text eol=lf
Makefile text eol=lf

# PowerShell: CRLF
*.ps1   text eol=crlf

# Binary
*.png   binary
*.jpg   binary
*.zip   binary
