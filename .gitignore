iptv/dist/*.m3u
iptv/dist/*.xml

# Rasterized branding (regenerated by `make assets`); keep SVG sources
assets/branding/*.png
assets/branding/*.jpg

# Media-quality audit reports
media-scan-report.tsv

# Smoke-test scratch dirs
/tmp/_kodi_smoke/

# Claude session state — local-only
.claude/
